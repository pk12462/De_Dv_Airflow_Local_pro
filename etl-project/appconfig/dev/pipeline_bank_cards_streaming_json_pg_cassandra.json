{
  "generalInfo": {
    "appName": "bank_cards_live_stream_pg_cassandra",
    "processType": "Streaming",
    "carId": "${CARID}",
    "deploymentType": "OnPrem"
  },
  "streaming": {
    "poll_interval_sec": 1,
    "max_batches": 4,
    "batch_size": 25
  },
  "connections": {
    "postgres": {
      "connectionRef": "postgres_bank_cards_live_stream"
    },
    "cassandra": {
      "connectionRef": "cassandra_bank_cards_live_stream"
    }
  },
  "mainFlow": [
    {
      "transformationList": [
        {
          "generalInfo": {
            "transformationName": "bank_cards_json_stream_source",
            "transformationType": "Source",
            "order": 0
          },
          "props": {
            "srcSysName": "local_jsonl_file",
            "srcSysProp": {
              "filePath": "/mnt/${CARID}-cda-fileshare-1/inbound/bank/bank_data.json"
            }
          }
        },
        {
          "generalInfo": {
            "transformationName": "expression1",
            "transformationType": "expression",
            "order": 1
          },
          "props": {
            "runtimeTransform": {
              "type": "add_current_timestamp",
              "column": "processed_at"
            }
          },
          "inbound": {
            "src1": "bank_cards_json_stream_source"
          }
        },
        {
          "generalInfo": {
            "transformationName": "filter1",
            "transformationType": "filter",
            "order": 2
          },
          "props": {
            "column": "account_id"
          },
          "inbound": {
            "src1": "expression1"
          }
        },
        {
          "generalInfo": {
            "transformationName": "PostgreSQL-target",
            "transformationType": "Target",
            "order": 3
          },
          "props": {
            "tgtSysName": "PostgreSQL",
            "tgtSysProp": {
              "table": "bank_cards_stream"
            }
          },
          "inbound": {
            "src1": "filter1"
          }
        },
        {
          "generalInfo": {
            "transformationName": "Cassandra-target",
            "transformationType": "Target",
            "order": 4
          },
          "props": {
            "tgtSysName": "Cassandra",
            "tgtSysProp": {
              "keyspace": "learning",
              "table": "bank_cards_stream"
            }
          },
          "inbound": {
            "src1": "PostgreSQL-target"
          }
        }
      ]
    }
  ]
}

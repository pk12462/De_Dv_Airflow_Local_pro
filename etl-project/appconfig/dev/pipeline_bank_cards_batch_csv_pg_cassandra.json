{
  "generalInfo": {
    "appName": "bank_cards_daily_batch_pg_cassandra",
    "processType": "Batch",
    "carId": "${CARID}",
    "deploymentType": "OnPrem"
  },
  "connections": {
    "postgres": {
      "connectionRef": "postgres"
    },
    "cassandra": {
      "connectionRef": "cassandra"
    }
  },
  "mainFlow": [
    {
      "transformationList": [
        {
          "generalInfo": {
            "transformationName": "bank_cards_csv_source",
            "transformationType": "Source",
            "order": 0
          },
          "props": {
            "srcSysName": "local_csv",
            "srcSysProp": {
              "filePath": "/mnt/${CARID}-cda-fileshare-1/inbound/bank/bank_data.csv"
            }
          }
        },
        {
          "generalInfo": {
            "transformationName": "expression1",
            "transformationType": "expression",
            "order": 1
          },
          "props": {
            "runtimeTransform": {
              "type": "add_current_timestamp",
              "column": "processed_at"
            }
          },
          "inbound": {
            "src1": "bank_cards_csv_source"
          }
        },
        {
          "generalInfo": {
            "transformationName": "filter1",
            "transformationType": "filter",
            "order": 2
          },
          "props": {
            "column": "account_id"
          },
          "inbound": {
            "src1": "expression1"
          }
        },
        {
          "generalInfo": {
            "transformationName": "PostgreSQL-target",
            "transformationType": "Target",
            "order": 3
          },
          "props": {
            "tgtSysName": "PostgreSQL",
            "tgtSysProp": {
              "table": "bank_cards_daily"
            }
          },
          "inbound": {
            "src1": "filter1"
          }
        },
        {
          "generalInfo": {
            "transformationName": "Cassandra-target",
            "transformationType": "Target",
            "order": 4
          },
          "props": {
            "tgtSysName": "Cassandra",
            "tgtSysProp": {
              "keyspace": "learning",
              "table": "bank_cards_daily"
            }
          },
          "inbound": {
            "src1": "PostgreSQL-target"
          }
        }
      ]
    }
  ]
}

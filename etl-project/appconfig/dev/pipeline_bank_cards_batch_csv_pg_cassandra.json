{
  "pipelineName": "bank_cards_daily_batch_pg_cassandra",
  "mode": "batch",
  "source": {
    "type": "local_csv",
    "path": "etl-project/local_source/bank/bank_data.csv"
  },
  "transforms": [
    {"type": "filter_not_null", "column": "account_id"},
    {"type": "add_current_timestamp", "column": "processed_at"}
  ],
  "targets": [
    {"type": "postgres", "table": "bank_cards_daily"},
    {"type": "cassandra", "keyspace": "learning", "table": "bank_cards_daily"}
  ],
  "connections": {
    "postgres": {
      "host": "localhost",
      "port": 5432,
      "database": "learning_db",
      "user": "postgres",
      "password": "postgres"
    },
    "cassandra": {
      "hosts": ["127.0.0.1"],
      "port": 9042,
      "keyspace": "learning"
    }
  }
}

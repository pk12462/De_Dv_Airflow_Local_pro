# Cloudflare Tunnel token from Zero Trust dashboard
# Dashboard path: Access -> Tunnels -> <your tunnel> -> Docker command token
CLOUDFLARE_TUNNEL_TOKEN=replace-with-your-tunnel-token

# Unique public DNS hostname for this project (example)
AIRFLOW_PUBLIC_HOSTNAME=airflow-yourproject.example.com

# Airflow UI base URL should match your Cloudflare hostname
AIRFLOW__WEBSERVER__BASE_URL=https://airflow-yourproject.example.com


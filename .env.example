# ──────────────────────────────────────────────────────────────────────────────
# Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env with real credentials.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8081
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_SOURCE_TOPIC=raw.events
KAFKA_SINK_TOPIC=processed.events
KAFKA_DLQ_TOPIC=dead.letter.events
KAFKA_CONSUMER_GROUP_ID=de-dv-consumer-group

# ─── Spark ────────────────────────────────────────────────────────────────────
SPARK_MASTER_URL=local[*]
SPARK_APP_NAME=de-dv-spark-app
SPARK_EXECUTOR_MEMORY=2g
SPARK_DRIVER_MEMORY=1g
SPARK_EXECUTOR_CORES=2
SPARK_CHECKPOINT_DIR=/tmp/spark/checkpoints
SPARK_LOG_LEVEL=WARN

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/dedv_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=dedv_db
POSTGRES_USER=dedv_user
POSTGRES_PASSWORD=changeme

# ─── AWS / S3 ────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_DEFAULT_REGION=us-east-1
AWS_S3_BUCKET=de-dv-data-lake
AWS_S3_PREFIX=data

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Airflow 2.11 ────────────────────────────────────────────────────────────
AIRFLOW_UID=50000
AIRFLOW_GID=0
AIRFLOW__CORE__FERNET_KEY=change-this-to-a-real-fernet-key-32-bytes==
AIRFLOW__CORE__EXECUTOR=CeleryExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres/airflow
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql://airflow:airflow@postgres/airflow
AIRFLOW__CELERY__BROKER_URL=redis://:@redis:6379/0
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=true
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__API__AUTH_BACKENDS=airflow.api.auth.backend.basic_auth,airflow.api.auth.backend.session
AIRFLOW__SCHEDULER__ENABLE_HEALTH_CHECK=true
AIRFLOW_WWW_USER_USERNAME=admin
AIRFLOW_WWW_USER_PASSWORD=admin

# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
PIPELINE_CONFIG_PATH=pipelines/configs/app_connection_config.yaml
SHIELD_CONFIG_PATH=pipelines/shield/shield_values.yaml
EGRESS_CONFIG_PATH=pipelines/egress/egress_rules.yaml

